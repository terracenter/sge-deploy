# ─────────────────────────────────────────────────────────────────────────────
# SGE HA Docker — Variables de entorno
# Copiar a .env y completar TODOS los valores antes de arrancar.
# NUNCA subir .env al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Dominios ────────────────────────────────────────────────────────────────
SGE_DOMAIN=sge.humanbyte.net
PANEL_DOMAIN=panel-sge.humanbyte.net

# ─── TLS ─────────────────────────────────────────────────────────────────────
# Con IP pública y dominio real → letsencrypt
# Sin IP pública (local/pruebas) → selfsigned
TLS_RESOLVER=letsencrypt
ACME_EMAIL=terracenter@gmail.com

# ─── PostgreSQL principal ─────────────────────────────────────────────────────
DB_USER=sge
DB_PASSWORD=CAMBIAR_CONTRASENA_SEGURA

# Usuario de replicación (creado en el script 01-setup-replication.sh)
REPLICATOR_PASSWORD=CAMBIAR_CONTRASENA_REPLICACION

# ─── PostgreSQL sge-panel ─────────────────────────────────────────────────────
PANEL_DB_USER=sge_panel
PANEL_DB_PASSWORD=CAMBIAR_CONTRASENA_PANEL

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CAMBIAR_CONTRASENA_REDIS

# ─── sge-panel admin ──────────────────────────────────────────────────────────
PANEL_ADMIN_USER=admin
PANEL_ADMIN_PASSWORD=CAMBIAR_CONTRASENA_ADMIN

# ─── SMTP (opcional — si está vacío, los emails van al log) ──────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
