#!/bin/bash
set -e

# ─────────────────────────────────────────────────────────────────────────────
# SGE — prerm
# Se ejecuta ANTES de desinstalar o actualizar el paquete.
# ─────────────────────────────────────────────────────────────────────────────

case "$1" in
    remove|upgrade|deconfigure)
        if [ -d /run/systemd/system ]; then
            systemctl stop sge.service          2>/dev/null || true
            systemctl stop sge-frontend.service 2>/dev/null || true
            systemctl stop sge-traefik.service  2>/dev/null || true
            systemctl disable sge.service sge-frontend.service sge-traefik.service \
                2>/dev/null || true
        fi
        ;;

    failed-upgrade)
        ;;

    *)
        echo "prerm: argumento desconocido '$1'" >&2
        exit 1
        ;;
esac

exit 0
